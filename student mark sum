#include <stdio.h>

int main() {
    int n, sum = 0;
    
    // Read the five-digit integer
    scanf("%d", &n);
    
    // Iterate until the number becomes 0
    while (n > 0) {
        // Extract the last digit and add it to sum
        sum += (n % 10);
        
        // Remove the last digit from n
        n /= 10;
    }
    
    // Print the final sum
    printf("%d\n", sum);
    
    return 0;
}
